# ============================================================
# 测试/模型逻辑验证环境
# ============================================================
#
# 用途：
# - 单元测试仍然 mock LLM，不读取本文件。
# - 需要真实调用 API 验证 prompt、schema、hybrid 流程时，复制为 .env.test。
# - 测试 API 统一使用 DeepSeek；真实生产 .env 才使用 DeepSeek + Claude 混合。
#
# 使用：
#   cp .env.test.example .env.test
#   # 填入 DeepSeek API key 和测试输出目录
#   npm run brief:test-hybrid

LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-pro
LLM_TEMPERATURE=0.6

# 预处理：DeepSeek 低成本模型
LLM_PREPROCESS_API_KEY=sk-xxx
LLM_PREPROCESS_BASE_URL=https://api.deepseek.com
LLM_PREPROCESS_MODEL=deepseek-v4-flash
LLM_PREPROCESS_TEMPERATURE=0.2

# 测试 writer 也用 DeepSeek，避免测试场景误打 Claude/b.ai
LLM_WRITER_API_KEY=sk-xxx
LLM_WRITER_BASE_URL=https://api.deepseek.com
LLM_WRITER_MODEL=deepseek-v4-pro
# LLM_WRITER_TEMPERATURE=0.6

LLM_INPUT_PRICE_PER_1M_TOKENS=0.14
LLM_OUTPUT_PRICE_PER_1M_TOKENS=0.28
LLM_PREPROCESS_INPUT_PRICE_PER_1M_TOKENS=0.14
LLM_PREPROCESS_OUTPUT_PRICE_PER_1M_TOKENS=0.28
LLM_WRITER_INPUT_PRICE_PER_1M_TOKENS=0.14
LLM_WRITER_OUTPUT_PRICE_PER_1M_TOKENS=0.28

NEWS_BRIEFS_ROOT=/tmp/news-workflows-test-output
