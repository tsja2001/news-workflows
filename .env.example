# ============================================================
# LLM 配置 — 支持单模型和多模型融合
# ============================================================

# ── 默认模型（兼容旧配置，未配置 role 专用变量时回退至此） ──
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-pro
LLM_TEMPERATURE=0.6

# ── 预处理模型：DeepSeek（大批量压缩、聚类） ──
# 未配置 LLM_PREPROCESS_* 时自动回退到 LLM_*
# LLM_PREPROCESS_API_KEY=sk-xxx
# LLM_PREPROCESS_BASE_URL=https://api.deepseek.com
# LLM_PREPROCESS_MODEL=deepseek-v4-pro
# LLM_PREPROCESS_TEMPERATURE=0.2

# ── 最终写作模型：Claude（选题、观点、成文） ──
# 未配置 LLM_WRITER_* 时自动回退到 LLM_*
# LLM_WRITER_API_KEY=sk-ant-xxx
# LLM_WRITER_BASE_URL=https://api.b.ai/v1
# LLM_WRITER_MODEL=claude-sonnet-4-6
# LLM_WRITER_TEMPERATURE=0.7

# ── Token 价格（元/百万 token），用于审计日志成本估算 ──
# 默认价格（DeepSeek）
LLM_INPUT_PRICE_PER_1M_TOKENS=0.14
LLM_OUTPUT_PRICE_PER_1M_TOKENS=0.28

# 可按 role 配置专用价格
# LLM_PREPROCESS_INPUT_PRICE_PER_1M_TOKENS=0.14
# LLM_PREPROCESS_OUTPUT_PRICE_PER_1M_TOKENS=0.28
# LLM_WRITER_INPUT_PRICE_PER_1M_TOKENS=3.00
# LLM_WRITER_OUTPUT_PRICE_PER_1M_TOKENS=15.00

# ── 简报输出根目录，各 yaml 的 output.dir 只需配子文件夹名 ──
NEWS_BRIEFS_ROOT=/path/to/your/NewsBriefs
